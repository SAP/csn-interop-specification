{
  "$schema": "http://json.schemastore.org/package",
  "name": "@sap/csn-interop-specification",
  "version": "1.2.4",
  "description": "CSN Interop Specification.",
  "author": "SAP SE",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SAP/csn-interop-specification.git"
  },
  "homepage": "https://sap.github.io/csn-interop-specification/",
  "files": [
    "README.md",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/generated/spec/v1"
  ],
  "scripts": {
    "clean": "tsx src/clean.ts",
    "clear": "docusaurus clear",
    "build": "npm run generate && npm run build:ts && npm run build:docusaurus",
    "build:ts": "tsc -p ./tsconfig.json",
    "build:docusaurus": "docusaurus build",
    "generate": "npx @open-resource-discovery/spec-toolkit -c ./spec-toolkit.config.json",
    "postgenerate": "ts-node ./scripts/copyGeneratedToDestination.js",
    "format": "biome format --write .",
    "ci": "biome ci .",
    "lint": "biome lint .",
    "test": "npm run build && npm run test:unit",
    "test:unit": "jest --ci",
    "test:coverage": "jest --ci --collectCoverage",
    "test:watch": "jest --watchAll",
    "serve": "docusaurus serve",
    "prestart": "npm run clear",
    "start": "docusaurus start",
    "prepare": "is-ci || lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/plugin-client-redirects": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "0.55.1",
    "@open-resource-discovery/spec-toolkit": "0.8.0",
    "@swc/core": "1.11.24",
    "@swc/jest": "0.2.37",
    "@tsconfig/node20": "20.1.9",
    "@types/fs-extra": "11.0.4",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/lodash": "4.17.24",
    "@types/minimist": "1.2.5",
    "@types/node": "25.7.0",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.5",
    "gfm-escape": "0.2.0",
    "is-ci": "4.1.0",
    "jest": "30.4.2",
    "js-yaml": "4.1.1",
    "json-schema": "0.4.0",
    "json-schema-library": "11.4.0",
    "lefthook": "2.1.6",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
